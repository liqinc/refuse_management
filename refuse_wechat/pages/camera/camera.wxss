/* camera.wxss */
.container {
  padding-top: 100rpx; /* 为自定义导航栏留出空间 */
  width: 100%;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f9f9f9;
  padding-bottom: 50rpx;
}

/* 页面标题 */
.page-title {
  text-align: center;
  padding: 30rpx 0;
}

.page-title text {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

/* 提示信息 */
.page-description {
  text-align: center;
  padding-bottom: 30rpx;
}

.page-description text {
  font-size: 28rpx;
  color: #666;
}

/* 图片容器 */
.image-container {
  width: 100%;
  height: 400rpx;
  background-color: #fff;
  border-radius: 20rpx;
  margin: 20rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1px dashed #ddd;
}

/* 图片占位符 */
.image-placeholder {
  color: #999;
  font-size: 28rpx;
}

/* 按钮区域 */
.buttons-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 20rpx;
  background-color: #fff;
  margin: 20rpx;
  border-radius: 20rpx;
}

/* 本地上传按钮 */
.upload-btn {
  width: 100%;
  margin-bottom: 30rpx;
}

/* 拍摄按钮 */
.shoot-btn {
  width: 100%;
  margin-bottom: 30rpx;
}

/* 开始识别按钮 */
.identify-btn {
  width: 100%;
  background-color: #1296db;
  color: white;
  font-size: 32rpx;
}

/* 结果图片 */
.result-image {
  width: 100%;
  height: 400rpx;
  background-color: #f0f0f0;
  border-radius: 10rpx;
}

/* 识别结果数据 */
.result-data {
  font-size: 28rpx;
  color: #333;
  line-height: 44rpx;
  display: block;
  word-break: break-all;
  white-space: pre-wrap;
}

.result-info {
  flex: 1;
  padding: 30rpx;
  box-sizing: border-box;
}

.result-header {
  margin-bottom: 20rpx;
}

.result-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.result-content {
  margin-bottom: 30rpx;
}

.garbage-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.category-tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 50rpx;
  color: #fff;
  font-size: 28rpx;
  margin-bottom: 20rpx;
}

.garbage-desc,
.garbage-tips {
  font-size: 28rpx;
  color: #666;
  line-height: 44rpx;
  display: block;
  margin-bottom: 20rpx;
}

.result-actions {
  display: flex;
  justify-content: center;
  margin-top: 20rpx;
}