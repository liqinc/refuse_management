<!-- classify.wxml -->
<navigation-bar title="垃圾分类" background="#fff" color="#000" back="true"></navigation-bar>

<view class="container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <image src="/images/search.png" class="search-icon" />
    <input type="text" placeholder="搜索垃圾名称" value="{{searchQuery}}" bindinput="search" bindconfirm="executeSearch" class="search-input" />
    <button type="primary" bindtap="executeSearch" class="search-button" size="mini">{{isSearching ? '搜索中...' : '搜索'}}</button>
  </view>
  
  <!-- 搜索结果区域 -->
  <view wx:if="{{showSearchResults}}" class="search-results">
    <view class="results-header">
        <text>搜索结果</text>
        <image src="/images/close.svg" class="close-icon" bindtap="clearSearchResults" />
      </view>
    
    <view wx:if="{{isSearching}}" class="searching-container">
      <text>正在搜索...</text>
    </view>
    
    <block wx:elif="{{searchResults.length > 0}}">
      <view wx:for="{{searchResults}}" wx:key="id" class="search-result-item" bindtap="navigateToSearchDetail" data-item="{{item}}">
        <view class="result-info">
          <text class="result-name">{{item.category_name}}</text>
          <text class="result-type" style="background-color: {{item.color}};">{{item.type_name}}</text>
        </view>
        <text class="result-desc">{{item.description || '暂无描述信息'}}</text>
      </view>
    </block>
    
    <view wx:else class="no-results">
      <text>未找到相关垃圾信息</text>
    </view>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{isLoading}}" class="loading-container">
    <text class="loading-text">正在加载垃圾分类数据...</text>
  </view>

  <!-- 错误信息 -->
  <view wx:if="{{errorMsg && !isLoading}}" class="error-container">
    <text class="error-text">{{errorMsg}}</text>
    <button type="primary" bindtap="getRefuseTypes">重新加载</button>
  </view>

  <!-- 主要内容区域 -->
  <view wx:if="{{categories.length > 0 && !isLoading && !errorMsg}}">
    <!-- 分类导航 -->
    <view class="category-nav">
      <block wx:for="{{categories}}" wx:key="index">
        <view class="category-item" bindtap="navigateToDetail" data-category="{{item.name}}" style="background-color: {{item.color}};">
          <image src="{{item.icon}}" class="category-icon" />
          <text class="category-text">{{item.name}}</text>
        </view>
      </block>
    </view>

    <!-- 热门搜索 -->
    <view class="hot-search">
      <view class="section-title">热门搜索</view>
      <view class="hot-tags">
        <text class="hot-tag" bindtap="tapHotSearch" data-query="矿泉水瓶">矿泉水瓶</text>
        <text class="hot-tag" bindtap="tapHotSearch" data-query="电池">电池</text>
        <text class="hot-tag" bindtap="tapHotSearch" data-query="苹果核">苹果核</text>
        <text class="hot-tag" bindtap="tapHotSearch" data-query="纸巾">纸巾</text>
        <text class="hot-tag" bindtap="tapHotSearch" data-query="塑料袋">塑料袋</text>
      </view>
    </view>

    <!-- 垃圾分类指南（从数据库动态获取） -->
    <view class="guide-section">
      <view class="section-title" style="width: 614rpx; display: block; box-sizing: border-box; position: relative; left: -10rpx; top: 0rpx">垃圾分类指南</view>
      <view class="guide-list">
        <block wx:for="{{categories}}" wx:key="index">
          <view class="guide-item">
            <text class="guide-title">{{item.name}}</text>
            <text class="guide-desc">{{item.description || '暂无描述信息'}}</text>
          </view>
        </block>
      </view>
    </view>
  </view>

  <!-- 空数据状态 -->
  <view wx:if="{{categories.length === 0 && !isLoading && !errorMsg}}" class="empty-container">
    <text class="empty-text">暂无垃圾分类数据</text>
  </view>
</view>