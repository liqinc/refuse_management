/* classify.wxss */
.container {
  padding: 20rpx;
  padding-top: 100rpx; /* 为自定义导航栏留出空间 */
  background-color: #f8f8f8;
}

.search-bar {
  display: flex;
  align-items: center;
  background-color: #fff;
  border-radius: 50rpx;
  padding: 10rpx 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.search-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 10rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  height: 60rpx;
  line-height: 60rpx;
}

.category-nav {
  display: flex;
  flex-wrap: nowrap;
  justify-content: space-between;
  margin-bottom: 30rpx;
  padding: 0 10rpx;
}

.category-item {
  flex: 1;
  max-width: 160rpx;
  height: 160rpx;
  margin: 0 10rpx;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #fff;
}

.category-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 10rpx;
}

.category-text {
  font-size: 28rpx;
  font-weight: bold;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
  border-left: 8rpx solid #1296db;
}

.hot-tags {
  display: flex;
  flex-wrap: wrap;
}

.hot-tag {
  background-color: #fff;
  padding: 10rpx 20rpx;
  margin: 10rpx;
  border-radius: 50rpx;
  font-size: 26rpx;
  color: #666;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.guide-list {
  background-color: #fff;
  border-radius: 20rpx;
 
}

.guide-item {
  padding: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.guide-item:last-child {
  border-bottom: none;
}

.guide-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.guide-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 40rpx;
}

/* 加载状态样式 */
.loading-container {
  padding: 60rpx 0;
  text-align: center;
  background-color: #fff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* 错误信息样式 */
.error-container {
  padding: 40rpx;
  background-color: #fff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  text-align: center;
}

.error-text {
  font-size: 28rpx;
  color: #ff6b6b;
  margin-bottom: 30rpx;
  display: block;
}

/* 空数据状态样式 */
.empty-container {
  padding: 60rpx 0;
  text-align: center;
  background-color: #fff;
  border-radius: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 搜索按钮样式 */
.search-button {
  margin-left: 10rpx;
  height: 60rpx;
  line-height: 60rpx;
  font-size: 26rpx;
}

/* 搜索结果容器样式 */
.search-results {
  background-color: #fff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

/* 搜索结果头部样式 */
.results-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.results-header text {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.close-icon {
  width: 40rpx;
  height: 40rpx;
}

/* 搜索中状态样式 */
.searching-container {
  padding: 60rpx 0;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

/* 搜索结果项样式 */
.search-result-item {
  padding: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.search-result-item:last-child {
  border-bottom: none;
}

.result-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.result-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.result-type {
  padding: 5rpx 15rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #fff;
}

.result-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 40rpx;
}

/* 无搜索结果样式 */
.no-results {
  padding: 60rpx 0;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}