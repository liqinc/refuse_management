/* guide.wxss */

/* 自定义导航栏 */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 90rpx;
  background-color: #4CAF50;
  color: white;
  display: flex;
  align-items: center;
  z-index: 999;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.nav-back {
  width: 80rpx;
  height: 90rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.back-icon {
  font-size: 40rpx;
  font-weight: bold;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 36rpx;
  font-weight: bold;
}

/* 容器 */
.container {
  padding: 20rpx;
  padding-top: 120rpx;
  box-sizing: border-box;
}

/* 分类指南容器 */
.guide-container {
  width: 100%;
  background-color: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 40rpx;
}

/* 分类标签 */
.tab-container {
  display: flex;
  width: 100%;
  height: 90rpx;
  background-color: #f8f8f8;
  border-bottom: 1rpx solid #eee;
}

.tab {
  flex: 1;
  height: 90rpx;
  line-height: 90rpx;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab.active {
  color: #4CAF50;
  font-weight: bold;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background-color: #4CAF50;
  border-radius: 3rpx;
}

/* 分类内容 */
.tab-content {
  padding: 30rpx;
}

.content-item {
  min-height: 800rpx;
}

.category-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.category-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.category-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.category-desc {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 40rpx;
  line-height: 1.5;
}

.item-list {
  margin-top: 20rpx;
}

.guide-item {
  background-color: #f8f8f8;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.item-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.item-examples {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
  line-height: 1.5;
}

.item-tips {
  font-size: 26rpx;
  color: #999;
  line-height: 1.5;
  padding-left: 20rpx;
  border-left: 6rpx solid #4CAF50;
}

/* 搜索功能 */
.search-container {
  width: 100%;
  background-color: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  padding: 30rpx;
  box-sizing: border-box;
}

.search-header {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.search-box {
  display: flex;
  width: 100%;
  height: 80rpx;
  margin-bottom: 20rpx;
}

.search-input {
  flex: 1;
  height: 80rpx;
  background-color: #f8f8f8;
  border-radius: 40rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
}

.search-btn {
  width: 160rpx;
  height: 80rpx;
  background-color: #4CAF50;
  color: white;
  font-size: 28rpx;
  border-radius: 40rpx;
  margin-left: 20rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 0;
}

.search-result {
  margin-top: 30rpx;
  background-color: #f8f8f8;
  border-radius: 16rpx;
  padding: 20rpx;
}

.result-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.result-content {
  font-size: 28rpx;
  color: #4CAF50;
  line-height: 1.5;
}