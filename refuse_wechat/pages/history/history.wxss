/* history.wxss */

/* 自定义导航栏 */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 90rpx;
  background-color: #4CAF50;
  color: white;
  display: flex;
  align-items: center;
  z-index: 999;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.nav-back {
  width: 80rpx;
  height: 90rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.back-icon {
  font-size: 40rpx;
  font-weight: bold;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 36rpx;
  font-weight: bold;
}

/* 容器 */
.container {
  padding: 20rpx;
  padding-top: 120rpx;
  box-sizing: border-box;
}

/* 历史记录列表 */
.history-list {
  width: 100%;
}

.history-item {
  width: 100%;
  background-color: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 30rpx;
 
  display: flex;
  flex-direction: row;
}

.history-image {
  width: 180rpx;
  height: 180rpx;
}

.history-image image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.history-info {
  flex: 1;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.history-result {
  font-size: 32rpx;
  font-weight: bold;
  color: #4CAF50;
}

.history-time {
  font-size: 24rpx;
  color: #999;
}

.history-actions {
  width: 120rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.action-btn {
  width: 80rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  font-size: 24rpx;
  border-radius: 30rpx;
}

.delete-btn {
  background-color: #ff5252;
  color: white;
}

/* 空状态 */
.empty-state {
  width: 100%;
  height: 800rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.empty-icon {
  font-size: 120rpx;
  color: #ccc;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.empty-subtext {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 60rpx;
}

.go-home-btn {
  width: 300rpx;
  height: 80rpx;
  line-height: 80rpx;
  background-color: #4CAF50;
  color: white;
  font-size: 28rpx;
  border-radius: 40rpx;
}

/* 底部操作区 */
.bottom-actions {
  width: 100%;
  padding: 30rpx 0;
  display: flex;
  justify-content: center;
}

.clear-btn {
  width: 300rpx;
  height: 80rpx;
  line-height: 80rpx;
  background-color: #f5f5f5;
  color: #666;
  font-size: 28rpx;
  border-radius: 40rpx;
}