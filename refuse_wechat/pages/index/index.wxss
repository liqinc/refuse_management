.container {
  background-color: #f7f7f7;
  overflow: visible;
  flex-direction: column;
  height: auto;
  padding: 0;
  align-items: flex-start;
  justify-content: flex-start;
}

.swiper {
  width: 100%;
  height: 400rpx;
  overflow: visible;
  position: relative;
  z-index: 8;
  margin-top: 30rpx;
}

.swiper-item {
  overflow: visible;
  position: relative;
}

.swiper-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  z-index: 10;
  position: relative;
}

.nav-grid {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 10rpx;
  background-color: #fff;
  margin-bottom: 20rpx;
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.nav-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 10rpx;
}

.nav-text {
  font-size: 24rpx;
  color: #333;
}

.news-section {
  background-color: #fff;
  padding: 10rpx;
}

.news-title {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.news-title-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 10rpx;
}

.news-list {
  display: flex;
  flex-direction: column;
}

.news-item {
  display: flex;
  margin-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  padding-bottom: 20rpx;
}

.news-image {
  width: 200rpx;
  height: 150rpx;
  margin-right: 20rpx;
  border-radius: 10rpx;
}

.news-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.news-text {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 10rpx;
}

.news-subtext {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.news-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 22rpx;
  color: #999;
}

.news-stats {
  display: flex;
  align-items: center;
}

.news-stats-icon {
  width: 28rpx;
  height: 28rpx;
  margin-left: 10rpx;
  margin-right: 5rpx;
}

.floating-button {
  position: fixed;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #007aff;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.2);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 999;
  transition: transform 0.1s ease-out;
  touch-action: none;
}

.ai-icon {
  width: 50rpx;
  height: 50rpx;
}